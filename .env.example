# Midas deploy configuration — copy to `.env`, then `docker compose up -d`.
# Every value has a sensible default; an empty .env runs the offline mock feed.

# ── Data provider ───────────────────────────────────────────────────────────
# mock  — synthetic, deterministic, fully offline (default)
# yahoo — live equities/ETF/crypto via Yahoo Finance (needs outbound network)
# ccxt  — live crypto via a CCXT exchange (needs outbound network)
MIDAS_DATA_PROVIDER=mock

# For MIDAS_DATA_PROVIDER=ccxt: the exchange to pull data from (any ccxt id).
MIDAS_CCXT_EXCHANGE=binance
# Venues compared side-by-side in the ALLQ multi-exchange module.
MIDAS_CCXT_COMPARE=binance,coinbase,kraken,bitfinex,okx,kucoin

# ── AI copilot (optional) ───────────────────────────────────────────────────
# Set your Anthropic API key to enable the AI panel; leave blank to disable it.
ANTHROPIC_API_KEY=
MIDAS_AI_MODEL=claude-sonnet-4-6

# ── Serving ─────────────────────────────────────────────────────────────────
# Host port the terminal is served on → http://localhost:<port>
MIDAS_WEB_PORT=8080
# Server log verbosity: trace | debug | info | warn | error
LOG_LEVEL=info
# Background alerts: how often the server re-evaluates alert rules, in ms.
# (Rules + triggers persist in the `midas-data` volume.)
MIDAS_ALERT_INTERVAL_MS=15000
# Optional: POST fired alerts to a webhook for delivery with no browser open.
# A Discord or Slack incoming-webhook URL works as-is; custom endpoints get the
# raw triggers too. Leave blank to disable.
MIDAS_ALERT_WEBHOOK=

# ── Multi-user auth (optional) ──────────────────────────────────────────────
# Require login for the API + terminal. Off by default (single-user). When on,
# the terminal shows a login screen and each account gets its own private alerts,
# workspaces and portfolio, synced server-side so they follow you across devices.
MIDAS_AUTH_ENABLED=false
# Allow new accounts to register (the first user can always bootstrap one).
MIDAS_AUTH_ALLOW_SIGNUP=true
# Secret for signing session tokens — set this when auth is on, or tokens won't
# survive a restart. e.g. `openssl rand -hex 32`. Users, alerts, workspaces,
# portfolios, watchlists and notes all persist in the data dir (`midas-data` volume).
MIDAS_AUTH_SECRET=

# ── Account access, read-only (optional) ────────────────────────────────────
# READ-ONLY exchange API keys make BAL / ORD / POSN / FILLS show your real
# account. Midas is non-custodial: with trading disabled (below) it only ever
# calls read endpoints, and keys never leave this server.
MIDAS_CCXT_API_KEY=
MIDAS_CCXT_SECRET=
# Only for venues that require a passphrase (OKX, KuCoin, …).
MIDAS_CCXT_PASSWORD=
# With keys set, a read-only watcher polls open orders at this cadence and
# pushes fill notifications (toasts + the alert webhook). 0 = off; minimum
# 2000 to protect exchange rate limits.
MIDAS_ACCOUNT_WATCH_MS=10000

# ── On-chain / DEX (optional) ───────────────────────────────────────────────
# Set to `dexscreener` to serve live on-chain pools in the DEX panel; blank
# keeps the panel honestly synthetic/unavailable.
MIDAS_DEX_SOURCE=

# ── LIVE trading (opt-in — read SECURITY.md before enabling) ────────────────
# Master switch. Off (default) = the order ticket previews only and nothing can
# be placed or canceled. On = orders execute for real, behind every gate below.
MIDAS_TRADING_ENABLED=false
# Hard per-order USD notional cap; orders above it are rejected (0 = uncapped).
MIDAS_MAX_ORDER_USD=1000
# Cumulative UTC-day USD notional cap across all orders (0 = uncapped).
MIDAS_MAX_DAILY_USD=5000
# Trading normally requires MIDAS_AUTH_ENABLED=true. This override permits
# no-auth trading on a trusted host and REQUIRES a pinned MIDAS_CORS_ORIGIN
# (not *) so a malicious web page can't place orders cross-origin.
MIDAS_TRADING_ALLOW_NO_AUTH=false
# Pin to your terminal's exact origin (e.g. http://localhost:8080) for
# defense-in-depth; required for the no-auth trading override.
MIDAS_CORS_ORIGIN=*
