# Midas server configuration. Copy to .env and adjust as needed.

# Data provider:
#   mock   - synthetic, deterministic, offline (default)
#   yahoo  - live equities/ETF/crypto via Yahoo Finance (needs network)
#   ccxt   - live crypto via a CCXT exchange (needs network)
MIDAS_DATA_PROVIDER=mock

# For MIDAS_DATA_PROVIDER=ccxt: which exchange to use (any ccxt exchange id).
# Public market data needs no API keys. Symbols use BASE/QUOTE (e.g. BTC/USDT).
MIDAS_CCXT_EXCHANGE=binance

# API server
PORT=4000
HOST=0.0.0.0

# Allowed CORS origin for the web client
MIDAS_CORS_ORIGIN=*

# Log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info
