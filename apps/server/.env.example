# Midas server configuration. Copy to .env and adjust as needed.

# Data provider: "mock" (synthetic, offline) or "yahoo" (live, needs network)
MIDAS_DATA_PROVIDER=mock

# API server
PORT=4000
HOST=0.0.0.0

# Allowed CORS origin for the web client
MIDAS_CORS_ORIGIN=*

# Log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info
